# Frontend (Vite) — exposed to the browser, safe to be public
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...
VITE_SENTRY_DSN=

# Supabase Edge Function (src/supabase/functions/server) — set as Supabase
# secrets (`supabase secrets set`), NEVER as VITE_ variables. Anything
# prefixed VITE_ is inlined into the public JS bundle at build time.
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
SUPABASE_SERVICE_ROLE_KEY=

# Admin dashboard auth (/admin/*, /analytics/dashboard).
# ADMIN_PASSWORD is checked once, server-side, in the /admin-login route —
# it is never sent to or compared in the browser.
# ADMIN_SESSION_SECRET signs the session token issued after a successful
# login; every admin-only route verifies that signature before doing
# anything. Generate a long random value, e.g.: openssl rand -base64 32
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=
